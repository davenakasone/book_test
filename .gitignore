# Quarto render output + caches
book/_book/
book/.quarto/
book/index_files/
book/site_libs/
/.quarto/

# LaTeX intermediates. keep-tex still generates book/*.tex locally (handy for
# debugging glyph/layout issues) but we no longer COMMIT it — it drifts from
# source on every render and bloats diffs. The PDF is the deliverable.
book/*.tex
*.aux
*.log
*.toc
*.out
*.idx
*.ilg
*.ind
*.bbl
*.blg
*.fls
*.fdb_latexmk
*.synctex.gz
latex-shootout/build/

# Author's raw source material (template mode — see START-HERE.md); their
# originals shouldn't land in git. Extracted media does (it's a build input).
incoming/

# OS / editor
.DS_Store

# Built book — distributed via GitHub Releases, not committed (build.py
# still drops a local convenience copy here; it stays untracked)
/The-Starlight-Engine.pdf
